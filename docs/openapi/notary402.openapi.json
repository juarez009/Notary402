    "/v1/attestations": {
      "post": {
        "summary": "Issue an attestation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "signature_request_id",
                  "wallet_proof_id",
                  "payment_proof_id",
                  "agent_wallet"
                ],
                "properties": {
                  "signature_request_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "wallet_proof_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "payment_proof_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "agent_wallet": {
                    "type": "string",
                    "pattern": "^0x[0-9a-fA-F]{40}$"
                  },
                  "amoy_tx_hash": {
                    "type": "string",
                    "pattern": "^0x[0-9a-fA-F]{64}$"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Attestation issued, includes verification_url",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/Attestation"
                    },
                    {
                      "type": "object",
                      "required": [
                        "verification_url"
                      ],
                      "properties": {
                        "verification_url": {
                          "type": "string"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid body or missing proofs (error codes VALIDATION_ERROR, MissingWalletProof, MissingPaymentProof)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Signature request not found (error code NotFound)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Supabase audit store failure (error code AUDIT_STORE_ERROR)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List attestations",
        "responses": {
          "200": {
            "description": "All attestations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "attestations"
                  ],
                  "properties": {
                    "attestations": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Attestation"
                      }
                    }
                  }
                }
              }
            }
          },
          "502": {
            "description": "Supabase audit store failure (error code AUDIT_STORE_ERROR)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
