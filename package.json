  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm.cmd run build && node --test dist/**/*.test.js",
    "dev:api": "node --watch dist/apps/api/src/server.js",
