    "smoke:supabase": "node dist/scripts/smoke-supabase.js",
    "smoke:datamcp": "node dist/scripts/smoke-datamcp.js",
    "smoke:amoy": "node dist/scripts/smoke-amoy.js",
    "smoke:zavu": "node dist/scripts/smoke-zavu.js",
    "smoke:aperture": "node dist/scripts/smoke-aperture.js",
    "smoke:e2e-live": "node dist/scripts/smoke-e2e-live.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@supabase/supabase-js": "^2.110.0",
    "@vitejs/plugin-react": "^5.1.1",
    "fastify": "^5.6.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "viem": "^2.43.1",
    "vite": "^7.2.7",
    "zod": "^4.2.1"
