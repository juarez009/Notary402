{
  "name": "notary402",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/**/*.test.js",
    "dev:api": "node --env-file-if-exists=.env.live --watch dist/apps/api/src/server.js",
    "start:api": "node --env-file-if-exists=.env.live dist/apps/api/src/server.js",
    "start:mcp": "node --env-file-if-exists=.env.live dist/apps/mcp/src/server.js",
    "dev:web": "vite --host 0.0.0.0 --port 3000 apps/web",
    "build:web": "vite build apps/web --outDir ../../dist --emptyOutDir",
    "configure:polar": "npm run build && node --env-file-if-exists=.env.live dist/scripts/configure-polar.js",
    "check:live-config": "node --env-file-if-exists=.env.live dist/scripts/check-live-config.js",
    "db:migrate": "node --env-file-if-exists=.env.live dist/scripts/db-migrate.js",
    "smoke:supabase": "node --env-file-if-exists=.env.live dist/scripts/smoke-supabase.js",
    "smoke:datamcp": "node --env-file-if-exists=.env.live dist/scripts/smoke-datamcp.js",
    "smoke:amoy": "node --env-file-if-exists=.env.live dist/scripts/smoke-amoy.js",
    "smoke:zavu": "node --env-file-if-exists=.env.live dist/scripts/smoke-zavu.js",
    "smoke:aperture": "node --env-file-if-exists=.env.live dist/scripts/smoke-aperture.js",
    "smoke:e2e-live": "node --env-file-if-exists=.env.live dist/scripts/smoke-e2e-live.js",
    "demo:agent": "npm run build && node --env-file-if-exists=.env.live dist/scripts/agent-hackathon-demo.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@supabase/supabase-js": "^2.110.0",
    "@vitejs/plugin-react": "^5.2.0",
    "fastify": "^5.6.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "viem": "^2.43.1",
    "vite": "^7.3.6",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0"
  }
}
